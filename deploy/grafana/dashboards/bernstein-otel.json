{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource — scrapes OTel Collector /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "histogram", "name": "Histogram", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "OTel Collector pipeline health + Bernstein agent concurrency, task throughput, cost accumulation, error rates, and latency distributions via OTLP metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Bernstein Overview",
      "type": "dashboard",
      "url": "/d/bernstein-main",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Agent Concurrency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total number of agents currently running across all roles. Spikes indicate burst activity; sustained high values may indicate task backlog.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 201,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Active Agents (now)",
      "type": "stat",
      "targets": [
        { "expr": "sum(bernstein_agents_active)", "legendFormat": "agents" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Agent concurrency over time, stacked by role. Shows how parallelism scales with workload.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 40,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 4, "y": 1 },
      "id": 202,
      "title": "Agent Concurrency Over Time (stacked by role)",
      "type": "timeseries",
      "targets": [
        { "expr": "bernstein_agents_active", "legendFormat": "{{ role }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Max observed agent concurrency in the selected time window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 203,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["max"] }
      },
      "title": "Peak Concurrency",
      "type": "stat",
      "targets": [
        { "expr": "sum(bernstein_agents_active)", "legendFormat": "agents" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total agents spawned over time (cumulative). Shows overall system activity.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "id": 204,
      "title": "Total Agents Spawned",
      "type": "timeseries",
      "targets": [
        { "expr": "bernstein_agents_spawned_total", "legendFormat": "spawned" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 210,
      "title": "Task Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Tasks completed and failed per minute over a 5-minute rolling window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "opm"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "completed/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 211,
      "title": "Task Throughput (tasks/min)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(bernstein_tasks_total{status=\"done\"}[5m]) * 60", "legendFormat": "completed/min" },
        { "expr": "rate(bernstein_tasks_total{status=\"failed\"}[5m]) * 60", "legendFormat": "failed/min" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Throughput broken down by task role — shows which agents are busiest.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "opm"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 212,
      "title": "Throughput by Role (tasks/min)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(bernstein_tasks_total{status=\"done\"}[5m]) * 60", "legendFormat": "{{ role }}" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 220,
      "title": "Cost Accumulation",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current total spend in USD.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 19 },
      "id": 221,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Cost",
      "type": "stat",
      "targets": [
        { "expr": "bernstein_cost_usd_total", "legendFormat": "total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Running USD spend per minute over a 5-minute window.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 19 },
      "id": 222,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Spend Rate ($/min)",
      "type": "stat",
      "targets": [
        { "expr": "rate(bernstein_cost_usd_total[5m]) * 60", "legendFormat": "$/min" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Cumulative cost over time — flat sections indicate no activity; steep sections indicate high spend periods.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 19 },
      "id": 223,
      "title": "Cumulative Cost Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "bernstein_cost_usd_total", "legendFormat": "total cost" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Cost per completed task. Rising values indicate efficiency degradation.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 23 },
      "id": 224,
      "title": "Cost per Task (rolling 5 min)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(bernstein_cost_usd_total[5m]) / rate(bernstein_tasks_total{status=\"done\"}[5m])",
          "legendFormat": "$/task"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 230,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Percentage of tasks failing in the last 10 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 28 },
      "id": 231,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Error Rate %",
      "type": "gauge",
      "targets": [
        {
          "expr": "rate(bernstein_tasks_total{status=\"failed\"}[10m]) / (rate(bernstein_tasks_total{status=\"done\"}[10m]) + rate(bernstein_tasks_total{status=\"failed\"}[10m])) * 100",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Task failures per minute over a 5-minute rolling window.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "opm"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 28 },
      "id": 232,
      "title": "Error Rate Over Time (failures/min)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(bernstein_tasks_total{status=\"failed\"}[5m]) * 60", "legendFormat": "failures/min" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "OTel Collector pipeline errors — dropped spans and metric points.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "dark-red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 28 },
      "id": 233,
      "title": "OTel Collector — Dropped Signals",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(otelcol_processor_dropped_spans[5m])", "legendFormat": "dropped spans/s" },
        { "expr": "rate(otelcol_processor_dropped_metric_points[5m])", "legendFormat": "dropped metrics/s" },
        { "expr": "rate(otelcol_processor_dropped_log_records[5m])", "legendFormat": "dropped logs/s" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 240,
      "title": "Latency Distributions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Task completion time percentiles (p50/p90/p99) over a 10-minute window. Derived from OTLP histogram data via OTel Collector.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p90" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 37 },
      "id": 241,
      "title": "Task Duration Percentiles (p50/p90/p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(bernstein_task_duration_seconds_bucket[10m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(bernstein_task_duration_seconds_bucket[10m]))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(bernstein_task_duration_seconds_bucket[10m]))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Agent spawn latency percentiles — time from task claim to first agent output.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 37 },
      "id": 242,
      "title": "Agent Spawn Latency (p50/p90/p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(bernstein_agent_spawn_duration_seconds_bucket[10m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(bernstein_agent_spawn_duration_seconds_bucket[10m]))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(bernstein_agent_spawn_duration_seconds_bucket[10m]))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Heatmap of task durations — shows shape of the latency distribution over time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "scheme": "Oranges" },
          "custom": {
            "fillOpacity": 80,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "scaleDistribution": { "type": "linear" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 46 },
      "id": 243,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "reverse": false, "scale": "exponential", "scheme": "Oranges", "steps": 64 },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "showColorScale": false, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "s" }
      },
      "title": "Task Duration Heatmap",
      "type": "heatmap",
      "targets": [
        { "expr": "sum(rate(bernstein_task_duration_seconds_bucket[5m])) by (le)", "legendFormat": "{{ le }}", "format": "heatmap" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 },
      "id": 250,
      "title": "OTel Collector Pipeline Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Spans/metric-points/log-records flowing through the OTel Collector pipeline per second.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 56 },
      "id": 251,
      "title": "OTel Collector Throughput (signals/s)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(otelcol_receiver_accepted_spans[1m])", "legendFormat": "accepted spans/s" },
        { "expr": "rate(otelcol_receiver_accepted_metric_points[1m])", "legendFormat": "accepted metrics/s" },
        { "expr": "rate(otelcol_exporter_sent_spans[1m])", "legendFormat": "exported spans/s" },
        { "expr": "rate(otelcol_exporter_sent_metric_points[1m])", "legendFormat": "exported metrics/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "OTel Collector queue usage — rising fill indicates downstream exporter is falling behind.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "id": 252,
      "title": "OTel Collector Queue Depth",
      "type": "timeseries",
      "targets": [
        { "expr": "otelcol_exporter_queue_size", "legendFormat": "{{ exporter }} queue" },
        { "expr": "otelcol_exporter_queue_capacity", "legendFormat": "{{ exporter }} capacity" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["bernstein", "otel", "opentelemetry", "agents", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "Bernstein — OTel Pipeline",
  "uid": "bernstein-otel",
  "version": 1
}
